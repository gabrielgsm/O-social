# ──────────────────────────────────────────────
# Social Media Automation Engine — .env.example
# Copie para .env e preencha os valores.
# NUNCA commite o arquivo .env!
# ──────────────────────────────────────────────

# ── Claude API ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── X (Twitter) API v2 ──────────────────────────
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_BEARER_TOKEN=

# ── Reddit API (PRAW) ───────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=PlanoEduBot/1.0

# ── Telegram Bot ────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Opções gerais ───────────────────────────────
DRY_RUN=false          # Se true, não publica — apenas loga
LOG_LEVEL=INFO
DRAFT_EXPIRY_HOURS=24
